# Environment Variables Configuration
# Copy this file to .env.local and fill in your actual values

# ===================== DATABASE =====================
DATABASE_URL=postgresql://user:password@localhost:5432/saukimart

# ===================== API KEYS =====================
GEMINI_API_KEY=your_gemini_api_key_here
AMIGO_API_KEY=your_amigo_api_key_here

# ===================== PAYMENT GATEWAY (FLUTTERWAVE) =====================
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST_xxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_xxxxxxxxxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_secret_here

# ===================== FIREBASE (for push notifications) =====================
NEXT_PUBLIC_FIREBASE_ENABLED=false
FIREBASE_SERVICE_ACCOUNT_JSON=your_firebase_service_account_json_here

# ===================== PUSH NOTIFICATIONS (Web Push) =====================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=admin@saukimart.online

# ===================== ADMIN =====================
ADMIN_PASSWORD=your_strong_admin_password_here
MY_BVN=your_bvn_for_flutterwave_settlement_here

# ===================== APPLICATION =====================
NEXT_PUBLIC_DOMAIN=www.saukimart.online
NEXT_PUBLIC_API_URL=https://www.saukimart.online/api
NODE_ENV=production

# ===================== THIRD PARTY PROXIES (Optional) =====================
# AMIGO_BASE_URL=https://amigo.ng/api/data/
# AWS_PROXY_URL=https://your-proxy-url.com
# PROXY_URL=https://your-proxy-url.com
