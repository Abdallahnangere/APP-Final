generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String        @id @default(uuid())
  name         String
  description  String?
  price        Float
  image        String
  inStock      Boolean       @default(true)
  category     String        @default("device")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model DataPlan {
  id           String        @id @default(uuid())
  network      String        
  data         String        
  validity     String        
  price        Float
  planId       Int           
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Agent {
  id                      String        @id @default(uuid())
  firstName               String
  lastName                String
  phone                   String        @unique
  pin                     String        
  balance                 Float         @default(0.0)
  cashbackBalance         Float         @default(0.0)
  totalCashbackEarned     Float         @default(0.0)
  cashbackRedeemed        Float         @default(0.0)
  isActive                Boolean       @default(true)
  flwAccountNumber        String?
  flwAccountName          String?
  flwBankName             String?
  
  createdAt               DateTime      @default(now()) 
  updatedAt               DateTime      @updatedAt
  transactions            Transaction[]
  cashbackHistory         CashbackEntry[]
  simOrders               AirtSIMOrder[] @relation("AirtSIMOrders")
}

model Transaction {
  id                  String    @id @default(uuid())
  tx_ref              String    @unique
  type                String    
  status              String    
  phone               String
  amount              Float
  agentCashbackAmount Float?    @default(0)
  cashbackProcessed   Boolean   @default(false)
  productId           String?
  product             Product?  @relation(fields: [productId], references: [id])
  planId              String?
  dataPlan            DataPlan? @relation(fields: [planId], references: [id])
  agentId             String?
  agent               Agent?    @relation(fields: [agentId], references: [id])
  customerName        String?
  deliveryState       String?
  idempotencyKey      String?   @unique
  paymentData         Json?     
  deliveryData        Json?     
  simOrderId          String?
  simOrder            AirtSIMOrder? @relation(fields: [simOrderId], references: [id])
  orderType           String    @default("regular")
  transactionCost     TransactionCost?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model SupportTicket {
  id        String   @id @default(uuid())
  phone     String
  message   String
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemMessage {
  id        String   @id @default(uuid())
  content   String
  type      String   @default("info")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebhookLog {
  id        String   @id @default(uuid())
  source    String
  payload   Json
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model CashbackEntry {
  id              String    @id @default(uuid())
  agentId         String
  agent           Agent     @relation(fields: [agentId], references: [id])
  type            String    // 'earned', 'redeemed'
  amount          Float
  transactionId   String?
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model TransactionCost {
  id              String    @id @default(uuid())
  transactionId   String    @unique
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  costPrice       Float     @default(0)
  salePrice       Float
  profit          Float     @default(0)
  profitMargin    Float     @default(0)
  itemType        String    @default("product")
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AirtSIMProduct {
  id              String    @id @default(uuid())
  name            String    @unique
  description     String?
  price           Float
  dataPackage     String?
  validity        String?
  isActive        Boolean   @default(true)
  image           String?
  orders          AirtSIMOrder[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AirtSIMOrder {
  id                      String    @id @default(uuid())
  orderRef                String    @unique
  productId               String
  product                 AirtSIMProduct @relation(fields: [productId], references: [id])
  phone                   String
  customerName            String
  email                   String?
  imeiNumber              String?
  simFrontImageUrl        String
  simBackImageUrl         String
  price                   Float
  agentId                 String?
  agent                   Agent?    @relation("AirtSIMOrders", fields: [agentId], references: [id])
  status                  String    @default("pending")
  transactionRef          String?
  adminNotes              String?
  estimatedActivationTime String    @default("5 hours")
  transactions            Transaction[]
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}